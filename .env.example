# =============================================================================
# EIGEN IAM — Variables d'environnement :: Keycloak Central
# Copier ce fichier en `.env` et remplir toutes les valeurs obligatoires.
# NE JAMAIS committer le fichier `.env` en clair dans Git.
# Les secrets de production doivent être gérés via HashiCorp Vault.
# =============================================================================

# --- Keycloak Admin Bootstrap ---
# Utilisé uniquement au premier démarrage pour créer l'admin initial.
# En production, désactiver cet admin via l'API Admin Keycloak après setup.
KC_ADMIN_USER=eigen-admin
KC_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION_USE_VAULT

# --- Base de données PostgreSQL ---
KC_DB_NAME=keycloak_central
KC_DB_USER=keycloak_central_usr
KC_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION_USE_VAULT

# --- Réseau et TLS ---
# En développement : localhost ou 127.0.0.1
# En production : sso.eigen.ga (avec certificat TLS valide)
KC_HOSTNAME=sso.eigen.ga

# --- Ports exposés (hôte Docker) ---
KC_HTTP_PORT_EXPOSE=8080
KC_HTTPS_PORT_EXPOSE=8443

# --- Kafka ---
# En développement : localhost:9093
# En production : adresse du broker Kafka interne
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9093

# --- EIGEN Système ---
EIGEN_VERSION=1.0.0

# --- Niveau de log ---
# Valeurs : TRACE, DEBUG, INFO, WARN, ERROR
# Ne pas utiliser DEBUG en production
KC_LOG_LEVEL=INFO
